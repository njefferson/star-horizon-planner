# Cloudflare Pages response headers. Security headers + a conservative CSP.
# The app is fully self-hosted except: Google Fonts (IBM Plex); hips2fits
# thumbnails (img-src alasky for display AND connect-src for the favourite
# precache's Cache-API fetches); Open-Meteo geocoding + weather and the
# Wikipedia summary API (connect-src). Every external feature degrades cleanly
# offline, so this list is the complete allow-list — anything else stays blocked.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: camera=(self), geolocation=(self), accelerometer=(self), gyroscope=(self), magnetometer=(self), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://alasky.u-strasbg.fr; connect-src 'self' https://api.open-meteo.com https://geocoding-api.open-meteo.com https://www.7timer.info https://en.wikipedia.org https://alasky.u-strasbg.fr; manifest-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'
